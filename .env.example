# ═══════════════════════════════════════════════════════
# LeadRénov — Variables d'environnement
# Copie ce fichier en .env.local et remplis les valeurs
# NE JAMAIS committer le .env.local sur GitHub
# ═══════════════════════════════════════════════════════

# Supabase — trouvé dans Settings > API du dashboard Supabase
VITE_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe — trouvé dans le dashboard Stripe (mode test d'abord)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXX

# App URL — pour les redirects OAuth
VITE_APP_URL=http://localhost:5173
