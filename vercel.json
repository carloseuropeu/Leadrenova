{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path*",     "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/import-sitadel",
      "schedule": "0 3 1 * *"
    }
  ],
  "functions": {
    "api/import-sitadel.js": {
      "maxDuration": 300
    }
  }
}
